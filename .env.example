GEMINI_API_KEY=your_gemini_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
JWT_SECRET=change_this_to_a_long_random_secret_string
PORT=5000
DEFAULT_CREDITS=20
NODE_ENV=development

# Feature 3 — Forgot Password (Gmail)
# 1. Enable 2-Step Verification on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Create an App Password for "Mail"
# 4. Paste it below (no spaces)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password
APP_URL=http://localhost:5173

# Feature 5 — Stripe Payments
# 1. Create account at https://stripe.com
# 2. Get keys from https://dashboard.stripe.com/apikeys
# 3. Create 3 products at https://dashboard.stripe.com/products
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_50=price_your_50_credit_price_id
STRIPE_PRICE_200=price_your_200_credit_price_id
STRIPE_PRICE_1000=price_your_1000_credit_price_id
